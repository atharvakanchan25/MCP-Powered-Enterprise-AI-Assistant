# Application
APP_NAME=MCP Enterprise AI Assistant
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-to-a-random-secret-key-at-least-32-chars
API_V1_PREFIX=/api/v1

# JWT
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=mcp_assistant
POSTGRES_USER=mcp_user
POSTGRES_PASSWORD=mcp_password
DATABASE_URL=postgresql+asyncpg://mcp_user:mcp_password@db:5432/mcp_assistant

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://redis:6379/0

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# Logging
LOG_LEVEL=INFO

# OpenAI
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o
EMBEDDING_DIMENSION=1536

# Qdrant
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=mcp_documents

# Storage
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=50

# RAG
CHUNK_SIZE=512
CHUNK_OVERLAP=64
RAG_TOP_K=5

# Agent
AGENT_MAX_ITERATIONS=10
AGENT_TEMPERATURE=0.1

# Tool integrations (all optional)
SERPAPI_KEY=your-serpapi-key
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASSWORD=your-app-password
GOOGLE_CREDENTIALS_JSON=
SLACK_BOT_TOKEN=xoxb-your-slack-token

# Redis cache
CACHE_TTL_SECONDS=300

# Monitoring
ENABLE_METRICS=true
